{
  "name": "medusa-starter-default",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "bridge": "tsx watch src/bridge/server.ts",
    "bridge:start": "tsx src/bridge/server.ts",
    "dev:all": "concurrently -n medusa,bridge -c blue,green \"medusa develop\" \"tsx watch src/bridge/server.ts\"",
    "start:all": "concurrently -n medusa,bridge -c blue,green \"medusa start\" \"tsx src/bridge/server.ts\"",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1046.0",
    "@aws-sdk/lib-storage": "^3.1046.0",
    "@medusajs/admin-sdk": "2.14.2",
    "@medusajs/cli": "2.14.2",
    "@medusajs/draft-order": "^2.14.2",
    "@medusajs/file-s3": "^2.14.2",
    "@medusajs/framework": "2.14.2",
    "@medusajs/medusa": "2.14.2",
    "axios": "^1.16.0",
    "ioredis": "^5.10.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.14.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
